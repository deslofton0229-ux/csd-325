# Countdown of bottles of beer on the wall

def countdown_bottles(bottles):
    while bottles > 1:
        print(f"{bottles} bottles of beer on the wall, {bottles} bottles of beer.")
        bottles -= 1
        print(f"Take one down, pass it around, {bottles} {'bottle' if bottles == 1 else 'bottles'} of beer on the wall.\n")
    # Last bottle
    print("1 bottle of beer on the wall, 1 bottle of beer.")
    print("Take it down, pass it around, no more bottles of beer on the wall.\n")

# Main program
def main():
    try:
        total_bottles = int(input("How many bottles of beer are on the wall? "))
        if total_bottles < 1:
            print("Please enter a positive number of bottles.")
            return
        countdown_bottles(total_bottles)
        print("Time to buy more beer!")
    except ValueError:
        print("Invalid input. Please enter a number.")
